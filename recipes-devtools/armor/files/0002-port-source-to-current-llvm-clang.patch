-  }
-
-  SaveAndRestore<bool> PHVal(HasEmptyPlaceHolder, PlaceHolder.empty());
-
-  printBefore(T, Quals, OS);
-  OS << PlaceHolder;
-  printAfter(T, Quals, OS);
