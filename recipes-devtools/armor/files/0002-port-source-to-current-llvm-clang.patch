-    case Qualifiers::OCL_Strong:
-      if (!Policy.SuppressStrongLifetime)
-        OS << "__strong";
-      break;
-
-    case Qualifiers::OCL_Weak: OS << "__weak"; break;
-    case Qualifiers::OCL_Autoreleasing: OS << "__autoreleasing"; break;
-    }
-  }
-
-  if (appendSpaceIfNonEmpty && addSpace)
