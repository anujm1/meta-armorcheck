-    if (!(lifetime == Qualifiers::OCL_Strong && Policy.SuppressStrongLifetime)){
-      if (addSpace)
-        OS << ' ';
-      addSpace = true;
-    }
-
-    switch (lifetime) {
-    case Qualifiers::OCL_None: llvm_unreachable("none but true");
